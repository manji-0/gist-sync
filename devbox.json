{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.2/.schema/devbox.schema.json",
  "packages": [
    "nodejs_22@latest",
    "pnpm_10@latest"
  ],
  "shell": {
    "scripts": {
      "bootstrap": [
        "pnpm install"
      ],
      "compile": [
        "pnpm run compile"
      ],
      "test": [
        "pnpm test"
      ],
      "watch": [
        "pnpm run watch"
      ],
      "package": [
        "pnpm run package"
      ],
      "dev": [
        "bash ./scripts/dev.sh"
      ]
    }
  }
}
